# ─────────────────────────────────────────────────────────────
# Spend Jot — root environment (used by docker-compose)
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────────────────────

# --- Database ---
# For LOCAL dev with the bundled Postgres (docker compose --profile local-db up):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/spendjot
# For Supabase, use the connection string from Project Settings → Database, e.g.:
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Credentials for the bundled local Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spendjot

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_DAYS=10
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Login throttling ---
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=5

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:3000

# Set to true only when serving over HTTPS (sets Secure flag on the refresh cookie)
COOKIE_SECURE=false

# --- Frontend → backend URL (browser-facing) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
