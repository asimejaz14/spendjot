# Spend Jot backend — copy to .env for local (non-docker) runs.

# Local Postgres or Supabase connection string (async driver):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spendjot

# Auth / JWT — generate a secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_DAYS=10
REFRESH_TOKEN_EXPIRE_DAYS=30

# Login throttling
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=5

# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000

# Set true when serving over HTTPS
COOKIE_SECURE=false

# Encrypt the DB connection (set true for Supabase's pooler)
DB_SSL=false

# Public site URL — used in the welcome email (logo + button link)
FRONTEND_URL=http://localhost:3000

# Outgoing email (welcome message on signup). Leave SMTP_PASSWORD blank to
# disable sending. For the spendjot.com mailbox the host settings are:
SMTP_HOST=server188.web-hosting.com
SMTP_PORT=465
SMTP_USERNAME=noreply@spendjot.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@spendjot.com
SMTP_FROM_NAME=Spend Jot
